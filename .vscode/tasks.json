{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "wails: build (debug)",
            "type": "shell",
            "command": "wails",
            "args": ["build", "-debug", "-devtools", "-nocolour"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": ["$go"]
        },
        {
            "label": "wails: dev",
            "type": "shell",
            "command": "wails",
            "args": ["dev", "-nocolour"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "presentation": {
                "clear": true,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "problemMatcher": {
                "owner": "wails",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Building application for development",
                    "endsPattern": "Watching \\(sub\\)/directory"
                }
            }
        },
        {
            "label": "wait-for-vite",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/wait-for-vite.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "wails: dlv attach",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/wails-dlv-attach.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["wails: dev"],
            "isBackground": true,
            "presentation": {
                "clear": true,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "problemMatcher": {
                "owner": "dlv",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Attaching Delve",
                    "endsPattern": "API server listening"
                }
            }
        }
    ]
}
