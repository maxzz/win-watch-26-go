{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Wails: Debug \u2014 Go (internal)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "buildFlags": "-tags=dev",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "frontend: vite",
            "env": {
                "WW_DEBUG": "1",
                "devserver": "localhost:34115",
                "frontenddevserverurl": "http://localhost:5173",
                "assetdir": "${workspaceFolder}/frontend/dist"
            },
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "Wails: Debug \u2014 Web (internal)",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:34115",
            "webRoot": "${workspaceFolder}/frontend",
            "preLaunchTask": "wait: devserver",
            "presentation": {
                "hidden": true
            }
        }
    ],
    "compounds": [
        {
            "name": "Wails: Debug",
            "configurations": [
                "Wails: Debug \u2014 Go (internal)",
                "Wails: Debug \u2014 Web (internal)"
            ],
            "stopAll": true
        }
    ]
}
